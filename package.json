{
  "name": "gluten-free-map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch backend/server.mjs",
    "dev:web": "vite --config frontend/vite.config.mjs",
    "start": "node backend/server.mjs",
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc -p frontend/tsconfig.json && vite build --config frontend/vite.config.mjs",
    "build:api": "node --check backend/server.mjs && node --check backend/scripts/create-admin.mjs",
    "lint": "eslint .",
    "preview": "vite preview --config frontend/vite.config.mjs --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uploadthing/react": "^7.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@workos-inc/node": "^8.10.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pigeon-maps": "^0.22.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "typescript": "~5.9.3",
    "uploadthing": "^7.7.4",
    "vite": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0"
  },
  "overrides": {
    "effect": "3.21.0",
    "picomatch": "4.0.4"
  }
}
